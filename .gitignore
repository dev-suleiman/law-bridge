# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/

# Environment files — NEVER commit these
.env
.env.local
.env.*.local
.env.production

# Python
__pycache__/
*.py[cod]
*.pyd
.Python
ml-service/__pycache__/
ml-service/*.pyc
training/__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/

# Model weights — too large for git, use Supabase Storage
model/
training/data/
training/source_docs/
ml-service/corpus/

# Misc
.DS_Store
*.log
.vercel
.turbo
coverage/
.nyc_output/


# Local .terraform directories
.terraform/

# Terraform lock file (keep this if you want consistent provider versions across machines)
# .terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files
*.tfplan
*.plan

# Crash log
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variables files that may contain secrets
*.tfvars
*.tfvars.json

# Except example var files — safe to commit
!example.tfvars
!*.tfvars.example

# CLI config
.terraformrc
terraform.rc