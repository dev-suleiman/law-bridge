# LawBridge GH — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.
#
#   cp .env.example .env.local

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (Drizzle / Postgres) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/postgres

# ── ML microservice ───────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_SECRET=your-shared-secret-at-least-32-chars
MODEL_MODE=stub
GROK_API_KEY=your-grok-api-key

# Pinecone (optional for local dev — ML service falls back to FAISS)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=lawbridge-legal-corpus
PINECONE_ENVIRONMENT=us-east-1-aws

# Mistral mode only
HF_TOKEN=your-huggingface-token

# ── Translation (GhanaNLP / Khaya) ────────────────────────────────────────────
KHAYA_AI_API_KEY=your-khaya-key
KHAYA_AI_BASE_URL=https://translation-api.ghananlp.org

# ── Payments (Paystack) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your-secret-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-public-key
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=noreply@lawbridge.gh

# ── Optional ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# SENTRY_DSN=
